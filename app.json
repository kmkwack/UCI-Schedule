{
  "expo": {
    "name": "ClassMate",
    "slug": "classmate",
    "owner": "parksihyun",
    "scheme": "com.parksihyun.classmate",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parksihyun.classmate",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "instagram",
          "instagram-stories"
        ],
        "UIApplicationSceneManifest": {
          "UIApplicationSupportsMultipleScenes": false,
          "UISceneConfigurations": {}
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.parksihyun.classmate"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "ClassMate uses your photo library so you can attach images to community posts.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ClassMate uses your photo library so you can save schedule snapshots and share campus content.",
          "savePhotosPermission": "ClassMate saves your schedule snapshots to your photo library when you choose Save Schedule."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "reminders"
        }
      ],
      "expo-sharing",
      "expo-web-browser",
      "expo-font",
      "expo-image"
    ],
    "extra": {
      "eas": {
        "projectId": "29e496cc-1ff6-4471-9d56-e1b9128d7196"
      }
    }
  }
}
