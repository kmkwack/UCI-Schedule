{
  "expo": {
    "name": "ClassMate",
    "slug": "classmate",
    "owner": "seanss-organization",
    "scheme": "com.classmate.app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.classmate.app",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "UIApplicationSceneManifest": {
          "UIApplicationSupportsMultipleScenes": false,
          "UISceneConfigurations": {}
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "ClassMate uses your photo library so you can attach images to community posts.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ClassMate uses your photo library so you can save schedule snapshots and share campus content.",
          "savePhotosPermission": "ClassMate saves your schedule snapshots to your photo library when you choose Save Schedule."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "reminders"
        }
      ],
      "expo-sharing",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "b40288cf-e9ba-49ee-8c59-1bef199d37b4"
      }
    }
  }
}
